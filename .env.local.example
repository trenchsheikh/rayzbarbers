# Database — use Supabase *Transaction* pooler URL on Vercel (port 6543, ?pgbouncer=true)
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:6543/postgres?pgbouncer=true

# Barber dashboard login (defaults: ray / pass)
ADMIN_USERNAME=ray
ADMIN_PASSWORD=pass
ADMIN_SESSION_SECRET=change-me-in-production

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=bookings@rayzbarbers.com

# Optional — live Google reviews (Places API New). Without this, curated Google reviews are shown.
# https://developers.google.com/maps/documentation/places/web-service/overview
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
