# Database (Supabase Postgres connection string)
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Comma-separated admin emails allowed to access /admin
ADMIN_ALLOWED_EMAILS=ray@rayzbarbers.com

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=bookings@rayzbarbers.com

# Optional — live Google reviews (Places API New). Without this, curated Google reviews are shown.
# https://developers.google.com/maps/documentation/places/web-service/overview
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
